# === MinIO Configuration ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=lakehouse

# === Kafka Configuration ===
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC_SENSOR=sensor-readings

# === Forest Configuration ===
FOREST_CENTER_LAT=15.3350
FOREST_CENTER_LON=108.2528
NUM_PLOTS_X=5
NUM_PLOTS_Y=5
SENSORS_PER_PLOT=3

# === Date Range (1 year historical) ===
HISTORICAL_START=2024-04-10
HISTORICAL_END=2025-04-09

# === Spark Configuration ===
SPARK_DRIVER_MEMORY=1g
SPARK_CORES=2
